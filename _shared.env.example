# crewdock shared config — reference for `data/_shared.env` (chmod 600).
# `crew init` writes `data/_shared.env` for you; this `.example` (at repo root)
# is the tracked reference. The real `data/_shared.env` is gitignored.
#   cp _shared.env.example data/_shared.env && chmod 600 data/_shared.env

# --- Deployment identity & ports (set by `crew init`) ---
# CREW_PROJECT prefixes every Docker container/image for this deployment so
# multiple deployments (prod/smoke) coexist on one daemon.
CREW_PROJECT=your-project-name   # set by `crew init` (gets a unique suffix, e.g. synt-fox42)
CREW_GATEWAY_HTTPS_PORT=443
CREW_ROUTER_PORT=9400
CREW_AUTH_PORT=9401
CREW_GATEWAY_LOCAL_PORT=9402

# --- Dashboard external access (gateway): Google SSO via oauth2-proxy ---
# Create a Google OAuth 2.0 "Web application" client and paste its credentials.
# Add the callback URL to the client's "Authorized redirect URIs"
# (`crew gateway up` prints the exact URL to register).
CREW_GOOGLE_CLIENT_ID=your-client-id.apps.googleusercontent.com
CREW_GOOGLE_CLIENT_SECRET=your-client-secret

# Session cookie encryption key. Generate with: openssl rand -base64 32
CREW_OAUTH_COOKIE_SECRET=

# NOTE: the access allow-list is NOT shared. Set CREW_ALLOWED_EMAILS
# (comma-separated Google accounts) PER INSTANCE in data/instances/<name>/instance.env.
# It is never inherited from this file; an instance with an empty whitelist is
# invisible and unreachable on the gateway (fail-closed).

# --- Optional: host uid/gid for agents that drop privileges ---
# crewdock injects these per-instance at `crew create`; set here only as a shared override.
# HERMES_UID=501
# HERMES_GID=20
