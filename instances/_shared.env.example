# crewdock shared config — copy to `_shared.env` (chmod 600) and fill in.
# The real `_shared.env` is gitignored; this `.example` is the tracked reference.
#   cp instances/_shared.env.example instances/_shared.env && chmod 600 instances/_shared.env

# --- Dashboard external access (`crew expose`): Google SSO via oauth2-proxy ---
# Create a Google OAuth 2.0 "Web application" client and paste its credentials.
# Add each instance's callback URL to the client's "Authorized redirect URIs"
# (crew expose prints the exact URL to register).
CREW_GOOGLE_CLIENT_ID=your-client-id.apps.googleusercontent.com
CREW_GOOGLE_CLIENT_SECRET=your-client-secret

# Session cookie encryption key. Generate with: openssl rand -base64 32
CREW_OAUTH_COOKIE_SECRET=

# Comma-separated allow-list of Google accounts permitted to sign in.
# REQUIRED for `crew expose` — exposing with an empty list is refused (fail-closed).
# Override per-instance with CREW_ALLOWED_EMAILS in instances/<name>/instance.env.
CREW_ALLOWED_EMAILS=you@example.com

# --- Optional: host uid/gid for agents that drop privileges ---
# crewdock injects these per-instance at `crew create`; set here only as a shared override.
# HERMES_UID=501
# HERMES_GID=20
