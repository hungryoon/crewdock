# crew runtime state — never commit
instances/*/data/
instances/*/instance.env
instances/*/docker-compose.yml
instances/*/meta.json
instances/_shared.env
instances/*/expose/
instances/_gateway/
instances/*/exposed
instances/.lock
# keep the seed template
!instances/_template/

# credential bundles — secrets, never commit
credentials/

# python
__pycache__/
*.pyc
.venv/
.pytest_cache/

# internal planning/spec docs — not part of the public repo
docs/superpowers/
